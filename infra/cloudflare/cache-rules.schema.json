{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cloudflare Cache Rules",
  "description": "Declarative config for Cloudflare Cache Rules (Rulesets API phase: http_request_cache_settings)",
  "type": "object",
  "required": ["rules"],
  "properties": {
    "description": {
      "type": "string",
      "description": "Human-readable description of this ruleset"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "expression", "action", "action_parameters", "enabled"],
        "properties": {
          "description": {
            "type": "string",
            "description": "Human-readable rule name"
          },
          "expression": {
            "type": "string",
            "description": "Cloudflare Ruleset Engine expression (Wire format)"
          },
          "action": {
            "type": "string",
            "enum": ["set_cache_settings"],
            "description": "Must be set_cache_settings for cache rules"
          },
          "action_parameters": {
            "type": "object",
            "required": ["cache"],
            "properties": {
              "cache": { "type": "boolean" },
              "edge_ttl": {
                "type": "object",
                "properties": {
                  "mode": {
                    "type": "string",
                    "enum": ["respect_origin", "override_origin", "bypass_by_default"]
                  },
                  "default": {
                    "type": "integer",
                    "description": "TTL in seconds (required when mode is override_origin)"
                  }
                },
                "required": ["mode"]
              },
              "browser_ttl": {
                "type": "object",
                "properties": {
                  "mode": {
                    "type": "string",
                    "enum": ["respect_origin", "override_origin", "bypass_by_default"]
                  },
                  "default": {
                    "type": "integer",
                    "description": "TTL in seconds (required when mode is override_origin)"
                  }
                },
                "required": ["mode"]
              }
            }
          },
          "enabled": { "type": "boolean" }
        }
      }
    }
  }
}
