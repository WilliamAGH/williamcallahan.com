#!/usr/bin/env sh
set -eu

echo "🚀 Running pre-commit checks on staged files..."

# Set up PATH to include bun, fall back to npx if bun not available
export PATH="$HOME/.bun/bin:$PATH"
if command -v bunx >/dev/null 2>&1; then
  RUNNER="bunx"
elif command -v npx >/dev/null 2>&1; then
  echo "ℹ️  Bun not found; falling back to npx."
  RUNNER="npx"
else
  echo "❌ Neither bunx nor npx is available in PATH."
  exit 1
fi

# Check if there are any staged files
if ! git diff --cached --name-only --diff-filter=ACMR | grep -q .; then
  echo "📭 No staged files to check"
  exit 0
fi

# Run oxlint on JS/TS files if any
if git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(js|jsx|ts|tsx)$' >/dev/null 2>&1; then
  echo "🔍 Running oxlint on TypeScript/JavaScript files..."
  git diff --cached --name-only --diff-filter=ACMR | while IFS= read -r file; do
    case "$file" in
      *.js|*.jsx|*.ts|*.tsx) printf '%s\0' "$file" ;;
    esac
  done | xargs -0 "$RUNNER" oxlint --fix || {
    echo "❌ Oxlint found issues!"
    exit 1
  }

  # Re-add files that were modified by oxlint --fix
  git diff --cached --name-only --diff-filter=ACMR | while IFS= read -r file; do
    case "$file" in
      *.js|*.jsx|*.ts|*.tsx) printf '%s\0' "$file" ;;
    esac
  done | xargs -0 git add --
fi

# Run oxfmt on JS/TS files only (oxfmt is alpha and only supports JavaScript/TypeScript)
# Note: For JSON/MD/YAML/CSS formatting, use Prettier via `bun run format` before committing
if git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(js|jsx|ts|tsx)$' >/dev/null 2>&1; then
  echo "✨ Running oxfmt on staged JS/TS files..."
  git diff --cached --name-only --diff-filter=ACMR | while IFS= read -r file; do
    case "$file" in
      *.js|*.jsx|*.ts|*.tsx) printf '%s\0' "$file" ;;
    esac
  done | xargs -0 "$RUNNER" oxfmt --write || {
    echo "❌ Oxfmt failed!"
    exit 1
  }

  # Re-add files that were modified by oxfmt
  git diff --cached --name-only --diff-filter=ACMR | while IFS= read -r file; do
    case "$file" in
      *.js|*.jsx|*.ts|*.tsx) printf '%s\0' "$file" ;;
    esac
  done | xargs -0 git add --
fi

echo "✅ Pre-commit checks passed!"
