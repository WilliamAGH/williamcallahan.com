graph TD
    subgraph "Client + API Entry"
        UI[UI Components<br/>(LogoImage, cards, profile)]
        API1[/api/logo]
        API2[/api/og-image]
        API3[/api/assets/[assetId]]
        API4[/api/cache/images<br/>(external only)]
        UI --> API1
        UI --> API2
        UI --> API3
        UI --> API4
    end

    subgraph "Validation + Routing"
        ZOD[Zod input validation]
        URL[URL/domain SSRF checks]
        ROUTER[UnifiedImageService<br/>source routing + dedupe]
        API1 --> ZOD
        API2 --> ZOD
        API3 --> ZOD
        API4 --> ZOD
        ZOD --> URL --> ROUTER
    end

    subgraph "Processing"
        FETCH[Provider fetches<br/>(Google/Clearbit/DDG/OG)]
        ANALYZE[Image analysis + format checks]
        STREAM[Streaming upload path for large payloads]
        ROUTER --> FETCH --> ANALYZE
        ANALYZE --> STREAM
    end

    subgraph "Persistence + Delivery"
        S3[S3/Spaces objects]
        MANIFEST[Image manifests + blocklists]
        CDN[CDN URLs]
        NEXTIMG[Next.js optimizer<br/>for first-party CDN hosts]
        STREAM --> S3
        ANALYZE --> S3
        S3 --> MANIFEST
        S3 --> CDN --> NEXTIMG
    end

    style ROUTER fill:#e3f2fd,stroke:#1976d2,stroke-width:2px
    style S3 fill:#fff3e0,stroke:#ef6c00,stroke-width:2px
    style CDN fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
