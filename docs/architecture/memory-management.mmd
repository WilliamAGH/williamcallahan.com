graph TB
    subgraph "Request Pipeline"
        REQ[Incoming Request]
        PROXY[proxy.ts<br/>auth + CSP + request controls]
        HANDLER[Route Handler / Server Function]
        REQ --> PROXY --> HANDLER
    end

    subgraph "Runtime Safeguards"
        SIZE[Size + timeout limits<br/>(fetch/stream boundaries)]
        STREAM[Streaming uploads/downloads<br/>(bounded IO path)]
        ASYNC[AsyncOperationsMonitor<br/>operation lifecycle tracking]
        HANDLER --> SIZE
        HANDLER --> STREAM
        HANDLER --> ASYNC
    end

    subgraph "Durable Layers"
        DB[PostgreSQL]
        S3[S3/Spaces]
        CACHE[Next.js Cache Components]
        HANDLER --> CACHE
        HANDLER --> DB
        HANDLER --> S3
    end

    subgraph "Platform Behavior"
        RUNTIME[Node.js Process]
        ORCH[Container Orchestrator<br/>(restart on OOM)]
        RUNTIME --> ORCH
    end

    style PROXY fill:#e3f2fd,stroke:#1976d2,stroke-width:2px
    style CACHE fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style DB fill:#fff3e0,stroke:#ef6c00,stroke-width:2px
    style S3 fill:#fff3e0,stroke:#ef6c00,stroke-width:2px
